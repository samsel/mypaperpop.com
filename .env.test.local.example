# Playwright E2E Testing Environment Variables
# Copy to .env.test.local and fill in values.
# NEVER commit .env.test.local — it's gitignored.

# ─── Test User ────────────────────────────────────────────────────────
# Email of an existing user in your local database
# The optional name is used by account page tests when present.
TEST_USER_EMAIL=demo-test-user@example.com
TEST_USER_NAME=Demo Test User

# ─── Test Auth ────────────────────────────────────────────────────────
# Shared secret for dev-only test-auth API. Must match TEST_AUTH_SECRET in .env.
TEST_AUTH_SECRET=test-e2e-secret-do-not-use-in-prod

# ─── Test Storage ─────────────────────────────────────────────────────
# Playwright forces the app server to use these values for generated test
# artifacts. Use local MinIO or a clearly marked dev/test S3-compatible bucket.
# Never point automated tests at production storage.
TEST_AWS_ENDPOINT_URL=http://127.0.0.1:9000
TEST_AWS_ACCESS_KEY_ID=minioadmin
TEST_AWS_SECRET_ACCESS_KEY=minioadmin
TEST_AWS_S3_BUCKET_NAME=mypaperpop-test
TEST_AWS_DEFAULT_REGION=us-east-1
