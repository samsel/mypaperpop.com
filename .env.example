# MyPaperPop Environment Variables
# Copy to .env and fill in values. Note: must be .env, not .env.local.
# Run `pnpm db:setup` to create .env from hosted service credentials.

# ─── Database (required) ──────────────────────────────────────────────
# PostgreSQL connection string. This localhost value is safe for build/typecheck
# smoke tests, but migrations and runtime database access require a real DB.
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/mypaperpop_dev

# ─── Auth (required) ──────────────────────────────────────────────────
# Random secret for signing JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_random_secret

# Google OAuth credentials — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# ─── Stripe (required) ────────────────────────────────────────────────
# Secret key and webhook signing secret from https://dashboard.stripe.com
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

# ─── S3-Compatible Storage (required) ────────────────────────────────
# S3 endpoint, credentials, and bucket name for image storage.
# Use local MinIO, Cloudflare R2, AWS S3, or another S3-compatible provider.
AWS_ENDPOINT_URL=https://storage.example.com
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET_NAME=your_bucket_name
AWS_DEFAULT_REGION=auto

# ─── AI Providers (required) ──────────────────────────────────────────
# xAI Grok Imagine for image generation
XAI_API_KEY=replace_with_xai_api_key
# Google Gemini 2.5 Flash-Lite for chat refinement + content safety
GEMINI_API_KEY=replace_with_gemini_api_key

# ─── App URL (optional) ───────────────────────────────────────────────
# Used for absolute URLs (e.g. share links). Defaults to http://localhost:3000
BASE_URL=http://localhost:3000

# ─── PostHog Analytics (optional) ─────────────────────────────────────
# Client-side analytics. App works without these.
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Feedback Email via Resend (optional) ─────────────────────────────
# Resend API key for sending user feedback emails
# RESEND_API_KEY=replace_with_resend_api_key
# Recipient address for feedback submissions
# # This is a Resend limitation — on their free tier without a verified domain, you can only send
#  emails to your own address.
# FEEDBACK_EMAIL_TO=feedback@example.com

# ─── Axiom Logging (optional) ─────────────────────────────────────────
# Structured log aggregation. Typically production only.
# AXIOM_DATASET=mypaperpop-logs
# AXIOM_TOKEN=replace_with_axiom_token

# Optional: enables Braintrust tracing for Vercel AI SDK calls.
# BRAINTRUST_API_KEY=replace_with_braintrust_api_key
# BRAINTRUST_PROJECT_NAME=My Project
# Required when configuring Braintrust online scoring rules from scripts.
# Copy this from the Braintrust project settings.
# BRAINTRUST_PROJECT_ID=00000000-0000-0000-0000-000000000000
# Optional for EU/self-hosted data planes.
# BRAINTRUST_API_URL=https://api.braintrust.dev
# Optional: 1 scores every production trace, 0.1 scores 10%.
# BRAINTRUST_ONLINE_SCORING_SAMPLING_RATE=1

# Optional: Braintrust eval judge configuration. The target provider is always
# the app's configured provider; only the judge is configurable.
AI_EVAL_JUDGE_PROVIDER=gemini
AI_EVAL_JUDGE_MODEL=gemini-2.5-flash-lite
# AI_EVAL_JUDGE_BASE_URL=http://localhost:11434/v1
# AI_EVAL_JUDGE_API_KEY=replace_with_judge_api_key
# AI_EVAL_TRIAL_COUNT=1
# AI_EVAL_MAX_CONCURRENCY=1

# ─── Geo / Currency Testing (optional) ────────────────────────────────
# ISO 3166-1 alpha-2 country code to simulate localized pricing in dev.
# Example: DEV_COUNTRY=IN → shows ₹ prices. Omit or US for USD.
# DEV_COUNTRY=US

# ─── E2E Testing (optional) ───────────────────────────────────────────
# Shared secret between dev server and Playwright for test auth.
# Must match TEST_AUTH_SECRET in .env.test.local. See .env.test.local.example.
# TEST_AUTH_SECRET=test-e2e-secret-do-not-use-in-prod

# ─── Platform / build-time vars (set automatically, not by you) ───────
# NODE_ENV        — Set by Next.js (development | production | test)
# VERCEL_ENV      — Set by Vercel (development | preview | production)
# CI              — Set by CI runners (GitHub Actions, etc.)
# CAPACITOR_ENV   — Set when running native app builds
