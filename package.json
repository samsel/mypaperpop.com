{
  "private": true,
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "node scripts/dev-with-env.mjs",
    "internal:check": "node scripts/check-internal-overlay.mjs",
    "check:boundaries": "node scripts/check-repo-boundaries.mjs",
    "prebuild": "node scripts/optimize-landing-images.mjs",
    "build": "next build",
    "optimize:images": "node scripts/optimize-landing-images.mjs",
    "start": "pnpm db:migrate && next start",
    "db:setup": "npx tsx lib/db/setup.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "pnpm test:all",
    "test:all": "pnpm exec tsc --noEmit && pnpm test:unit:coverage && pnpm build && pnpm exec playwright test --workers=1",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:mobile-gate": "playwright test --project=mobile-landing-gate",
    "test:desktop-gate": "playwright test --project=desktop-landing-gate",
    "test:landing-gates": "playwright test --project=mobile-landing-gate --project=desktop-landing-gate",
    "test:functional-visual-gates": "playwright test --project=app-functional-visual-gate-desktop --project=app-functional-visual-gate-mobile",
    "test:runtime-gates": "playwright test tests/e2e/runtime-errors.spec.ts --project=chromium",
    "test:production-gate": "pnpm test:all",
    "eval:ai": "pnpm eval:ai:planning && pnpm eval:ai:safety && pnpm eval:ai:age-fit && pnpm eval:ai:grounding && pnpm eval:ai:followup && pnpm eval:ai:real-images",
    "eval:ai:validate": "tsx --import ./evals/server-only-shim.mjs evals/validate-cases.ts",
    "eval:ai:planning": "tsx --import ./evals/server-only-shim.mjs evals/planning.eval.ts",
    "eval:ai:safety": "tsx --import ./evals/server-only-shim.mjs evals/safety.eval.ts",
    "eval:ai:age-fit": "tsx --import ./evals/server-only-shim.mjs evals/age-fit.eval.ts",
    "eval:ai:grounding": "tsx --import ./evals/server-only-shim.mjs evals/grounding.eval.ts",
    "eval:ai:followup": "tsx --import ./evals/server-only-shim.mjs evals/followup.eval.ts",
    "eval:ai:real-images": "tsx --import ./evals/server-only-shim.mjs evals/real-image.eval.ts",
    "braintrust:push-scorers": "braintrust push braintrust/online-scorers.ts --if-exists replace",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.83",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@axiomhq/pino": "^1.7.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-visually-hidden": "^1.2.6",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@use-gesture/react": "^10.3.1",
    "ai": "^6.0.208",
    "autoprefixer": "^10.5.0",
    "braintrust": "^3.18.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.30",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.15",
    "postgres": "^3.4.9",
    "posthog-js": "^1.391.2",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.14.0",
    "server-only": "^0.0.1",
    "sharp": "^0.35.2",
    "sonner": "^2.0.7",
    "stripe": "^22.2.2",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/canvas-confetti": "^1.9.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
